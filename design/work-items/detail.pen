                              "type": "text",
                              "id": "BRI7D",
                              "fill": "$--foreground",
                              "content": "// lib/auth/index.ts",
                              "lineHeight": 1.6,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "FMU2V",
                              "fill": "$--foreground",
                              "content": "export const auth = betterAuth({",
                              "lineHeight": 1.6,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "QTSTX",
                              "fill": "$--foreground",
                              "content": "  socialProviders: { google: { clientId, clientSecret } },",
                              "lineHeight": 1.6,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "R8QN7E",
                              "fill": "$--foreground",
                              "content": "  account: { accountLinking: { trustedProviders: ['google'] } },",
                              "lineHeight": 1.6,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "H71Bg",
                              "fill": "$--foreground",
                              "content": "});",
                              "lineHeight": 1.6,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12.5,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
