                              "fill": "$--muted-foreground",
                              "content": "— why this matters",
                              "fontFamily": "$--font-serif",
                              "fontSize": 14,
                              "fontWeight": "normal",
                              "fontStyle": "italic"
                            }
                          ]
                        },
                        {
