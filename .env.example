# Local dev DB (run `./scripts/db-up.sh` to start Postgres in Docker).
# Host port is 5433 (not 5432) to avoid conflicting with other local
# Postgres instances. The container internally uses 5432.
DATABASE_URL="postgresql://prodect:prodect@localhost:5433/prodect"

# Auth — Better-Auth (Story 1.1)
# BETTER_AUTH_SECRET: required. Used to sign session cookies. Generate a
# fresh 32-byte secret for each environment with:
#   openssl rand -base64 32
# In production, store this in the Vercel dashboard (Settings → Environment
# Variables). Rotating the secret invalidates all active sessions.
BETTER_AUTH_SECRET=

# BETTER_AUTH_URL: the public origin Better-Auth uses to build callback
# URLs (OAuth round-trips, email links). Optional in local dev — defaults
# to http://localhost:3000 — but MUST be set in production to the canonical
# public URL (e.g. https://prodect-core.vercel.app). Setting Vercel's
# automatic VERCEL_URL is not enough because it omits the protocol.
# BETTER_AUTH_URL=http://localhost:3000

# Backend AI service — used in Epic 4 to call prodect-ai server-to-server
# PRODECT_AI_URL=http://localhost:8001
# PRODECT_AI_INTERNAL_KEY=
